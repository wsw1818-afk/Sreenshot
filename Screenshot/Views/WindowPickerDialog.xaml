<Window x:Class="Screenshot.Views.WindowPickerDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="캡처할 창 선택"
        Width="480" Height="400"
        MinWidth="360" MinHeight="280"
        WindowStartupLocation="CenterOwner"
        Background="#1e1e1e"
        ResizeMode="CanResize"
        ShowInTaskbar="False">

    <Window.Resources>
        <Style x:Key="ListItemStyle" TargetType="ListBoxItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#cccccc"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}"
                                BorderThickness="0,0,0,1"
                                BorderBrush="#2a2a2a">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#2a2a2a"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#0e4b8a"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="캡처할 창을 선택하세요"
                   Foreground="#aaaaaa" FontSize="13" Margin="0,0,0,10"/>

        <!-- 검색 -->
        <Border Grid.Row="1" Background="#2a2a2a" CornerRadius="4" Margin="0,0,0,8">
            <TextBox x:Name="SearchBox"
                     Background="Transparent" Foreground="White"
                     BorderThickness="0" Padding="8,6"
                     FontSize="13" CaretBrush="White"
                     TextChanged="SearchBox_TextChanged">
                <TextBox.Resources>
                    <Style TargetType="TextBox">
                        <Style.Triggers>
                            <Trigger Property="Text" Value="">
                                <Setter Property="Background">
                                    <Setter.Value>
                                        <VisualBrush Stretch="None" AlignmentX="Left">
                                            <VisualBrush.Visual>
                                                <TextBlock Text="🔍 창 이름 검색..."
                                                           Foreground="#555555" FontSize="13"
                                                           Margin="8,6"/>
                                            </VisualBrush.Visual>
                                        </VisualBrush>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </TextBox.Resources>
            </TextBox>
        </Border>

        <!-- 창 목록 -->
        <Border Grid.Row="2" Background="#252525" CornerRadius="4">
            <ListBox x:Name="WindowList"
                     Background="Transparent"
                     BorderThickness="0"
                     ItemContainerStyle="{StaticResource ListItemStyle}"
                     MouseDoubleClick="WindowList_MouseDoubleClick"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel>
                            <TextBlock Text="{Binding Title}"
                                       FontSize="13" TextTrimming="CharacterEllipsis"/>
                            <TextBlock Text="{Binding SizeText}"
                                       FontSize="11" Foreground="#666666" Margin="0,2,0,0"/>
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Border>

        <!-- 버튼 -->
        <Grid Grid.Row="3" Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock x:Name="CountText" Grid.Column="0"
                       Foreground="#555555" FontSize="11"
                       VerticalAlignment="Center"/>

            <Button Grid.Column="1" Content="취소"
                    Width="80" Height="32" Margin="0,0,8,0"
                    Background="#333333" Foreground="White"
                    BorderThickness="0" Cursor="Hand"
                    Click="Cancel_Click"/>

            <Button Grid.Column="2" Content="캡처"
                    x:Name="CaptureButton"
                    Width="80" Height="32"
                    Background="#0078d4" Foreground="White"
                    BorderThickness="0" Cursor="Hand"
                    IsDefault="True"
                    Click="Capture_Click"/>
        </Grid>
    </Grid>
</Window>
